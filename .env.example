# ===========================================
# Remicon 프로젝트 통합 환경변수 설정 템플릿
# ===========================================
#
# 이 파일을 .env로 복사하고 실제 값으로 수정하세요:
# cp .env.example .env

# =====================================
# Backend 환경변수 (서버용)
# =====================================
GOOGLE_API_KEY=your_google_api_key_here

# Supabase 데이터베이스 URL
SUPABASE_DB_URL=postgresql://user:password@host:port/database

# =====================================
# Frontend 환경변수 (브라우저용)
# 주의: VITE_ 접두사는 브라우저에 노출됨
# =====================================
VITE_API_URL=http://localhost:8000

# =====================================
# 공통 설정
# =====================================
NODE_ENV=development
DEBUG=true

# =====================================
# 프로덕션 설정 예시
# =====================================
# VITE_API_URL=https://your-vercel-domain.vercel.app
# GOOGLE_API_KEY=your_production_api_key
# SUPABASE_DB_URL=postgresql://postgres.xxx:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
# NODE_ENV=production
# DEBUG=false