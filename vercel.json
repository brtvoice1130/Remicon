{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "api/hello.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/test.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/statistics.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/upload_pdf.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/data.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/ai-extractions.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/hello",
      "dest": "api/hello.py"
    },
    {
      "src": "/api/test",
      "dest": "api/test.py"
    },
    {
      "src": "/api/statistics",
      "dest": "api/statistics.py"
    },
    {
      "src": "/api/upload_pdf",
      "dest": "api/upload_pdf.py"
    },
    {
      "src": "/api/data",
      "dest": "api/data.py"
    },
    {
      "src": "/api/ai-extractions",
      "dest": "api/ai-extractions.py"
    },
    {
      "src": "/api/ai-extractions/(.*)",
      "dest": "api/ai-extractions.py"
    },
    {
      "src": "/index-(.+)\\.js",
      "dest": "/index-$1.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/.*\\.(js|css|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$",
      "dest": "/$0",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}