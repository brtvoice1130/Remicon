{
  "functions": {
    "api/hello.py": {
      "runtime": "@vercel/python"
    },
    "api/test.py": {
      "runtime": "@vercel/python"
    },
    "api/statistics.py": {
      "runtime": "@vercel/python"
    }
  },
  "routes": [
    {
      "src": "/api/hello",
      "dest": "api/hello.py"
    },
    {
      "src": "/api/test",
      "dest": "api/test.py"
    },
    {
      "src": "/api/statistics/(.*)",
      "dest": "api/statistics.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}